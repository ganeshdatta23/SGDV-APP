{
  "expo": {
    "name": "Guru Dhigvandanam",
    "slug": "darshanam-compass-native-new",
    "scheme": "sgdv",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app_icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/swamiji-darshan.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.darshanamcompassnative",
      "entitlements": {
        "com.apple.developer.usernotifications.time-sensitive": true
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs your location to show the direction to the sacred place.",
        "NSMotionUsageDescription": "This app needs access to your device motion sensors for compass functionality.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app_icon.png",
        "backgroundColor": "#FF6B35"
      },
      "package": "com.darshanamcompassnative",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "VIBRATE",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "WAKE_LOCK",
        "USE_FULL_SCREEN_INTENT",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/audio/custom_alert.wav"
          ],
          "enableBackgroundRemoteNotifications": true,
          "icon": "./assets/images/app_icon.png",
          "color": "#FF6B35",
          "iosDisplayInForeground": true
        }
      ],
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": false,
          "supportsPictureInPicture": false
        }
      ],
      "./plugins/withAndroidAlarm",
      "expo-audio",
      "expo-location",
      "expo-task-manager"
    ],
    "extra": {
      "eas": {
        "projectId": "7d6ac752-f13c-4ec8-b4ad-97647e4bad25"
      }
    },
    "owner": "amardattadola2"
  }
}
