# =============================================================================
# SGVD backend — environment template. Copy to .env and fill in real values:
#
#   cp .env.example .env
#
# A single .env at the repo root is the only env file: the app, the maintenance
# scripts (scripts/_env.py, seed_defaults.py), and the deploy scripts
# (scripts/deploy_vercel.sh, cloudflare/deploy_worker.sh) all read from it.
# Real environment variables always win over .env. Never commit your .env.
# =============================================================================

# --- Backend selector --------------------------------------------------------
# "turso" | "postgres". See TURSO.md for the resolution table.
DB_BACKEND=turso

# --- App ---------------------------------------------------------------------
SECRET_KEY=replace_with_a_strong_secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
environment=development
debug=True
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Turso / libSQL (app connection) -----------------------------------------
TURSO_DATABASE_URL=libsql://<your-db>.turso.io
TURSO_HTTP_URL=https://<your-db>.turso.io
TURSO_AUTH_TOKEN=<full-access db auth token>

# --- Turso platform API (manages org/databases/tokens; not read by the app) --
TURSO_API_KEY=<turso platform api key>
TURSO_ORG=<turso org slug>
TURSO_GROUP=default
TURSO_DATABASE_NAME=<db name>

# --- Postgres / Supabase (used only when DB_BACKEND=postgres) -----------------
POSTGRES_URL_NON_POOLING=postgres://user:password@host:5432/postgres?sslmode=require

# --- Vercel (deploy tooling; not read by the app) ----------------------------
VERCEL_API_KEY=<vercel api token>
# VERCEL_OIDC_TOKEN is auto-generated by `vercel dev` / `vercel env pull`.

# --- Cloudflare (deploy tooling; read by cloudflare/deploy_worker.sh) ---------
CLOUDFLARE_API_KEY=<cloudflare api token>
